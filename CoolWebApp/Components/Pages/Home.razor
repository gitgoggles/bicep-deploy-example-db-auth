@page "/"
@using Microsoft.EntityFrameworkCore
@using CoolWebApp.Data
@inject AppDbContext db

<PageTitle>Product inventory · Razor + htmx</PageTitle>

<section class="hero">
    <p class="eyebrow">ASP.NET Core 10 + Razor components + htmx</p>
    <h1>Product inventory</h1>
    <p class="lede">
        This page is a statically server-rendered Razor component. The table below is fetched
        by htmx from a minimal API endpoint and rendered by another Razor component.
    </p>
</section>

<section class="add-product" aria-labelledby="add-product-heading">
    <div class="section-heading">
        <h2 id="add-product-heading">Add a product</h2>
    </div>

    <form class="form-card"
          hx-post="/api/products"
          hx-target="#product-rows"
          hx-swap="beforeend"
          hx-on::after-request="if(event.detail.successful) this.reset()">
        <AntiforgeryToken />
        <div class="form-grid">
            <div class="form-field">
                <label for="product-name">Product</label>
                <input id="product-name" name="name" type="text" required />
            </div>
            <div class="form-field">
                <label for="product-category">Category</label>
                <input id="product-category" name="category" type="text" required />
            </div>
            <div class="form-field">
                <label for="product-price">Price</label>
                <input id="product-price" name="price" type="number" min="0" step="1" required />
            </div>
            <div class="form-field">
                <label for="product-stock">Stock</label>
                <input id="product-stock" name="stock" type="number" min="0" step="1" required />
            </div>
            <button class="button" type="submit">Add product</button>
        </div>
    </form>
</section>

<section>
    <div class="section-heading">
        <h2 id="inventory-heading">Inventory</h2>
    </div>

    <div id="table-loading" class="htmx-indicator" role="status">Loading inventory…</div>
	<div class="table-card">
    <table>
        <thead>
            <tr>
                <th scope="col">ID</th>
                <th scope="col">Product</th>
                <th scope="col">Category</th>
                <th scope="col" class="number">Price</th>
                <th scope="col" class="number">Stock</th>
            </tr>
        </thead>
        <tbody id="product-rows">
            @foreach (var product in products)
            {
                <ProductRow Product="product" />
            }
        </tbody>
    </table>
	</div>
</section>
        <noscript>JavaScript is required to load the inventory table.</noscript>

@code {
    private List<Product> products = [];

    protected override async Task OnInitializedAsync()
    {
        products = await db.Products.AsNoTracking().OrderBy(p => p.Id).ToListAsync();
    }
}

