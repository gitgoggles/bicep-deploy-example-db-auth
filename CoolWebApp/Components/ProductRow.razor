@using CoolWebApp.Models

<tr>
  <td>@Product.Id</td>
  <td>@Product.Name</td>
  <td>@Product.Category</td>
  <td class="number">@Product.Price.ToString("C")</td>
  <td class="number">
	@if (Product.Stock == 0)
	{
		<span class="out-of-stock">Out of stock</span>
	}
	else
	{
		@Product.Stock
	}
  </td>
</tr>

@code {
	[Parameter, EditorRequired]
	public required Product Product {get; set;}
}
